# ===========================================
# DATAPLEX BUSINESS UI - CONFIGURATION
# ===========================================
# Replace the values below with yours!

# --- GCP Project ---
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west1
GCP_LOCATION=europe-west1

# --- External Projects ---
# If your data (BigQuery tables) is in a DIFFERENT project, add it here
# Space or comma separated list of project IDs
# Example: EXTERNAL_PROJECTS=my-data-project other-project
EXTERNAL_PROJECTS=

# --- Cloud Run ---
SERVICE_NAME=dataplex-business-ui
ARTIFACT_REPO_NAME=dataplex-business-ui
IMAGE_NAME=dataplex-business-ui

# --- OAuth 2.0 ---
# Create at: https://console.cloud.google.com/apis/credentials
# Type: Web Application
# Authorized redirect URIs: https://<your-cloud-run-url>/auth/google/callback
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# --- Admin ---
ADMIN_EMAIL=your-email@example.com
