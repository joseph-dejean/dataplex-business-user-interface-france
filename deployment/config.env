# ===========================================
# DATAPLEX BUSINESS UI - CONFIGURATION
# ===========================================
# Just replace the values below with yours!

# ---------------------------------------------
# PROJECT 1: WHERE THE APP RUNS (required)
# ---------------------------------------------
# This is YOUR project where Cloud Run will be deployed
PROJECT_1=your-main-project-id

# ---------------------------------------------
# EXTERNAL PROJECTS (optional)
# ---------------------------------------------
# Add projects you want to access BigQuery data from
# Separate multiple projects with spaces
# Example: EXTERNAL_PROJECTS="project-a project-b project-c"
EXTERNAL_PROJECTS="external-project-1 external-project-2"

# ---------------------------------------------
# YOUR IDENTITY (required)
# ---------------------------------------------
YOUR_EMAIL=your-email@example.com

# ---------------------------------------------
# APP ADMIN (required)
# ---------------------------------------------
# Who can approve access requests in the app
ADMIN_EMAIL=admin@example.com

# ---------------------------------------------
# GCP REGION (required)
# ---------------------------------------------
GCP_REGION=europe-west1
GCP_LOCATION=europe-west1

# ---------------------------------------------
# OAUTH CREDENTIALS (required)
# ---------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID > Web Application
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# ---------------------------------------------
# SERVICE NAMES (keep defaults or customize)
# ---------------------------------------------
SERVICE_NAME=dataplex-business-ui
ARTIFACT_REPO_NAME=dataplex-business-ui
IMAGE_NAME=dataplex-business-ui
