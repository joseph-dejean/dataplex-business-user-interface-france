# ============================================
# Terraform Variables - COPY THIS FILE
# ============================================
# 1. Copy this file to terraform.tfvars
# 2. Fill in your values
# 3. Run: terraform apply
#
# IMPORTANT: Never commit terraform.tfvars to Git (it contains secrets!)

# --- Required ---
project_id           = "your-gcp-project-id"
region               = "europe-west1"
google_client_id     = "123456789-xxxxx.apps.googleusercontent.com"
google_client_secret = "GOCSPX-xxxxxxxxxxxxx"
admin_email          = "your-email@example.com"

# --- Optional ---
app_name          = "dataplex-business-ui"
external_projects = ""           # e.g., "project-1 project-2"
docker_image_tag  = "latest"

# --- Optional: Email Notifications ---
# smtp_email    = "your-email@gmail.com"
# smtp_password = "your-app-password"
