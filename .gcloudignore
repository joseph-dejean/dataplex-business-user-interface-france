# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore

# Dependencies
node_modules/
**/node_modules/

# Build output (will be built in Cloud Build)
dist/
build/
**/dist/
**/build/

# Environment files
.env
.env.*
!.env.example
deploy.env
deployment/config.env
deployment/deploy.env

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
coverage/
.nyc_output/

# CI/CD configs
.gitlab-ci.yml
.travis.yml

# Misc
stats.html
.cache
.npm
.gemini
.codeoss
venv/
